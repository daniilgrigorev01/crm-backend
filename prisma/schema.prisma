generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  name      String
  surname   String
  lastname  String?
  contacts  Contact[]
}

enum ETypeContact {
  PHONE    @map("Телефон")
  EMAIL    @map("Email")
  FACEBOOK @map("Facebook")
  VK       @map("VK")
  OTHER    @map("Другое")
}

model Contact {
  id       Int          @id @default(autoincrement())
  type     ETypeContact
  value    String
  Client   Client       @relation(fields: [clientId], references: [id])
  clientId String
}
